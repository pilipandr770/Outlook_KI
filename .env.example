# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kompass_assistant"

# --- Evolution API (WhatsApp, self-hosted on Hostinger) ---
EVOLUTION_API_URL="https://your-hostinger-instance.example.com"
EVOLUTION_API_KEY="your-evolution-api-key"
EVOLUTION_INSTANCE_NAME="kompass-assistant"
# Public URL Evolution API should call for incoming messages, e.g. https://<your-deploy>.example.com/webhooks/whatsapp
PUBLIC_BASE_URL="http://localhost:3000"
# Required — the webhook endpoint rejects requests without a matching X-Webhook-Secret header
# (set automatically on the Evolution API side when connecting WhatsApp from the admin panel).
# Generate with `openssl rand -hex 32`.
WEBHOOK_SECRET="replace-with-a-long-random-string"

# --- Telegram (second channel, same conversation engine as WhatsApp) ---
# Create with @BotFather in Telegram (/newbot). Leave empty to disable this channel.
TELEGRAM_BOT_TOKEN=""

# --- AI provider: "anthropic" or "mistral" (EU-hosted alternative, same architecture) ---
AI_PROVIDER="anthropic"

# --- Anthropic Claude (used when AI_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-sonnet-5"

# --- Mistral (used when AI_PROVIDER=mistral) ---
MISTRAL_API_KEY="..."
MISTRAL_MODEL="mistral-large-latest"

# --- OpenAI (Whisper transcription) ---
OPENAI_API_KEY="sk-..."

# --- Microsoft Graph (per-advisor Outlook OAuth) ---
# Register a free Azure AD app (portal.azure.com -> App registrations -> New registration).
# Account type: "Accounts in any organizational directory and personal Microsoft accounts".
# Redirect URI (Web): {PUBLIC_BASE_URL}/calendar/oauth/callback
MS_CLIENT_ID="00000000-0000-0000-0000-000000000000"
MS_CLIENT_SECRET="your-client-secret"
MS_TENANT="common"

# 32-byte hex key used to encrypt stored refresh tokens, e.g. `openssl rand -hex 32`
TOKEN_ENCRYPTION_KEY="replace-with-64-hex-chars"

# --- Admin panel auth (prototype: single admin login) ---
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me"
ADMIN_JWT_SECRET="replace-with-a-long-random-string"

# --- Knowledge base source ---
WORDPRESS_SITE_URL="https://www.kompassfrankfurt.de"

PORT=3000
